log -header "Positive: mbase MSB one-hot (8'b1000_0000), shiftamt 3 bits"
log -push
design -reset
read_verilog <<EOT
module top(
	input  [11:0] a,
	input  [2:0]  shiftamt,
	output [11:0] y
);
	localparam [7:0] MBASE = 8'b1000_0000;
	assign y = a % (MBASE >> shiftamt);
endmodule
EOT
check -assert
equiv_opt -assert peepopt
design -load postopt
opt_clean
select -assert-count 0 t:$mod
select -assert-count 1 t:$and
select -assert-count 1 t:$shr
design -reset
log -pop


log -header "Positive: mbase non-MSB one-hot (8'b0010_0000)"
log -push
design -reset
read_verilog <<EOT
module top(
	input  [11:0] a,
