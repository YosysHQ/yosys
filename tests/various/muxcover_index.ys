opt
peepopt
techmap
opt
muxcover -mux8
clean
opt_expr -mux_bool

select -assert-count 4 t:$_MUX8_
select -assert-none t:$_MUX_ t:$_MUX4_ t:$_MUX16_
select -assert-none t:$_AND_ t:$_OR_ t:$_XOR_ t:$_NAND_ t:$_NOR_ t:$_XNOR_

techmap -map +/simcells.v t:$_MUX8_
