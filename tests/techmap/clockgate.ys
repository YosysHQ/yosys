#------------------------------------------------------------------------------

# Dedicated srst-aware ICGs are used for sdffe. Without SRST-capable ICGs, sdffe are skipped.
design -reset
read_verilog << EOT

module mix_pos(input clk, input en, input rst_n, input d, output reg q_dffe, output reg q_sdffe);
	always @(posedge clk) begin
		if (en)
			q_dffe <= d;
	end
	always @(posedge clk) begin
		if (!rst_n)
			q_sdffe <= 1'b0;
		else if (en)
			q_sdffe <= d;
	end
endmodule

module mix_neg(input clk, input en, input rst_n, input d, output reg q_dffe, output reg q_sdffe);
	always @(negedge clk) begin
		if (en)
			q_dffe <= d;
	end
	always @(negedge clk) begin
		if (!rst_n)
			q_sdffe <= 1'b0;
		else if (en)
			q_sdffe <= d;
	end
endmodule

EOT

proc
opt
design -save before_srst_icg_select

clockgate -pos pdk_icg ce:clkin:clkout -pos_srst pdk_icg_rst ce:clkin:clkout:rstn -neg npdk_icg ce:clkin:clkout -neg_srst npdk_icg_rst ce:clkin:clkout:rstn
select -module mix_pos -assert-count 1 t:\\pdk_icg
select -module mix_pos -assert-count 1 t:\\pdk_icg_rst
select -module mix_pos -assert-count 0 t:\\npdk_icg
select -module mix_pos -assert-count 0 t:\\npdk_icg_rst
select -module mix_neg -assert-count 0 t:\\pdk_icg
select -module mix_neg -assert-count 0 t:\\pdk_icg_rst
select -module mix_neg -assert-count 1 t:\\npdk_icg
select -module mix_neg -assert-count 1 t:\\npdk_icg_rst

design -load before_srst_icg_select
clockgate -pos pdk_icg ce:clkin:clkout -neg npdk_icg ce:clkin:clkout
select -module mix_pos -assert-count 1 t:\\pdk_icg
select -module mix_pos -assert-count 0 t:\\pdk_icg_rst
select -module mix_neg -assert-count 1 t:\\npdk_icg
select -module mix_neg -assert-count 0 t:\\npdk_icg_rst
