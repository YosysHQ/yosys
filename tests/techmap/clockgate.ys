#------------------------------------------------------------------------------

# Regression: 16-way sdffe coverage with optional ICG SRST port.
# Naming: sdffe_<clk><en><srst><prio>
#   clk:  0=negedge 1=posedge
#   en:   0=~en 1=en
#   srst: 0=active-low (!rst_n) 1=active-high (rst)
#   prio: 0=srst over ce 1=ce over srst
design -reset
read_verilog << EOT

module sdffe_0000(input clk, input en, input rst, input rst_n, input d, output reg q);
	always @(negedge clk) begin
		if (!rst_n) q <= 1'b0;
		else if (~en) q <= d;
	end
endmodule

module sdffe_0001(input clk, input en, input rst, input rst_n, input d, output reg q);
	always @(negedge clk) begin
		if (~en) q <= d;
		else if (!rst_n) q <= 1'b0;
	end
endmodule

module sdffe_0010(input clk, input en, input rst, input rst_n, input d, output reg q);
	always @(negedge clk) begin
		if (rst) q <= 1'b0;
		else if (~en) q <= d;
	end
endmodule

module sdffe_0011(input clk, input en, input rst, input rst_n, input d, output reg q);
	always @(negedge clk) begin
		if (~en) q <= d;
		else if (rst) q <= 1'b0;
	end
endmodule

module sdffe_0100(input clk, input en, input rst, input rst_n, input d, output reg q);
	always @(negedge clk) begin
		if (!rst_n) q <= 1'b0;
		else if (en) q <= d;
	end
endmodule

module sdffe_0101(input clk, input en, input rst, input rst_n, input d, output reg q);
	always @(negedge clk) begin
		if (en) q <= d;
		else if (!rst_n) q <= 1'b0;
	end
endmodule

module sdffe_0110(input clk, input en, input rst, input rst_n, input d, output reg q);
	always @(negedge clk) begin
		if (rst) q <= 1'b0;
		else if (en) q <= d;
	end
endmodule

module sdffe_0111(input clk, input en, input rst, input rst_n, input d, output reg q);
	always @(negedge clk) begin
		if (en) q <= d;
		else if (rst) q <= 1'b0;
	end
endmodule

module sdffe_1000(input clk, input en, input rst, input rst_n, input d, output reg q);
	always @(posedge clk) begin
		if (!rst_n) q <= 1'b0;
		else if (~en) q <= d;
	end
endmodule

module sdffe_1001(input clk, input en, input rst, input rst_n, input d, output reg q);
	always @(posedge clk) begin
		if (~en) q <= d;
		else if (!rst_n) q <= 1'b0;
	end
endmodule

module sdffe_1010(input clk, input en, input rst, input rst_n, input d, output reg q);
	always @(posedge clk) begin
		if (rst) q <= 1'b0;
		else if (~en) q <= d;
	end
endmodule

module sdffe_1011(input clk, input en, input rst, input rst_n, input d, output reg q);
	always @(posedge clk) begin
		if (~en) q <= d;
		else if (rst) q <= 1'b0;
	end
endmodule

module sdffe_1100(input clk, input en, input rst, input rst_n, input d, output reg q);
	always @(posedge clk) begin
		if (!rst_n) q <= 1'b0;
		else if (en) q <= d;
	end
endmodule

module sdffe_1101(input clk, input en, input rst, input rst_n, input d, output reg q);
	always @(posedge clk) begin
		if (en) q <= d;
		else if (!rst_n) q <= 1'b0;
	end
endmodule

module sdffe_1110(input clk, input en, input rst, input rst_n, input d, output reg q);
	always @(posedge clk) begin
		if (rst) q <= 1'b0;
		else if (en) q <= d;
	end
endmodule

module sdffe_1111(input clk, input en, input rst, input rst_n, input d, output reg q);
	always @(posedge clk) begin
		if (en) q <= d;
		else if (rst) q <= 1'b0;
	end
endmodule

EOT

