library (test_not_data) {
  cell (dlatchsr_not_data) {
    area : 1.0;
    pin (Q) {
      direction : output;
      function : "STATE";
    }
    pin (ENA) {
      clock : true;
      direction : input;
    }
    pin (D) {
      direction : input;
    }
    pin (RN) {
      direction : input;
    }
    pin (SN) {
      direction : input;
    }
    latch (STATE,STATEN) {
      clear : "!SN";
      enable : "ENA";
      data_in : "!D";
      preset : "!RN";
    }
  }
}