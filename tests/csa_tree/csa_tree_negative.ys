read_verilog <<EOT
module add_partial(
	input [7:0] a, b, c, d, e,
	output [7:0] mid, y
);
	wire [7:0] ab = a + b;
	assign mid = ab;
	assign y = ab + c + d + e;
endmodule
EOT
hierarchy -auto-top
proc
csa_tree
