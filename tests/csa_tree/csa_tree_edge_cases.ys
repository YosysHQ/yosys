read_verilog <<EOT
module fir_4tap(
	input clk,
	input [15:0] x, c0, c1, c2, c3,
	output reg [31:0] y
);
	reg [15:0] x1, x2, x3;
	always @(posedge clk) begin
		x1 <= x;
		x2 <= x1;
		x3 <= x2;
	end

	wire [31:0] sum = x*c0 + x1*c1 + x2*c2 + x3*c3;
	always @(posedge clk) y <= sum;
endmodule
EOT
hierarchy -auto-top
proc
csa_tree
select -assert-count 2 t:$fa
select -assert-count 1 t:$add
design -reset

