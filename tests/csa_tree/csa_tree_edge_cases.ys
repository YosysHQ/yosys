read_verilog <<EOT
module add_1bit(
	input a, b, c,
	output [1:0] y
);
	assign y = a + b + c;
endmodule
EOT
hierarchy -auto-top
proc
csa_tree
select -assert-count 1 t:$fa
select -assert-count 1 t:$add
design -reset

