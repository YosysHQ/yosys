read_verilog <<EOT
module sub_3op(
	input [7:0] a, b, c,
	output [7:0] y
);
	assign y = a - b + c;
endmodule
EOT
hierarchy -auto-top
proc
csa_tree
select -assert-count 2 t:$fa
select -assert-count 1 t:$add
select -assert-count 1 t:$not
select -assert-none t:$sub
design -reset

