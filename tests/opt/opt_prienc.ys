module test #(parameter int DEPTH = 32) (
    input  logic                    clk,
    input  logic                    rst_n,
    input  logic [DEPTH-1:0]        req,
    output logic [$clog2(DEPTH)-1:0] grant
);
    typedef logic [$clog2(DEPTH)-1:0] idx_t;
