  output wire y
);
  assign x[0] = a & b;
  assign x[1] = x[0] & c;
  assign x[2] = x[1] & d;
  assign y = x[1];
endmodule
EOF
check -assert
equiv_opt -assert opt_parallel_prefix
design -reset
log -pop

