log -header "Cross-type same direction: $shr then $sshr"
log -push
design -reset
read_rtlil <<EOF
autoidx 1
module \top
  wire width 8 input 1 \a
  wire width 3 input 2 \b
  wire width 3 input 3 \c
  wire width 8 output 4 \x
  wire width 8 \t
  cell $shr \shr_cell
    parameter \A_SIGNED 0
    parameter \B_SIGNED 0
    parameter \A_WIDTH 8
    parameter \B_WIDTH 3
    parameter \Y_WIDTH 8
    connect \A \a
    connect \B \b
    connect \Y \t
  end
  cell $sshr \sshr_cell
    parameter \A_SIGNED 1
    parameter \B_SIGNED 0
    parameter \A_WIDTH 8
    parameter \B_WIDTH 3
    parameter \Y_WIDTH 8
    connect \A \t
    connect \B \c
    connect \Y \x
  end
end
EOF
check -assert
opt_shift -combine
select -assert-count 1 t:$shr
select -assert-count 0 t:$sshr
select -assert-count 1 t:$add
design -reset
log -pop



