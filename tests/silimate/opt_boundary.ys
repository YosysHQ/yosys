module m(input a, input b, output y);
  assign y = a & b;
endmodule

module top(input a0, input b0, input a1, input b1, output y0, output y1);
  m u0(.a(a0), .b(b0), .y(y0));
  m u1(.a(a1), .b(b1), .y(y1));
endmodule
EOF
