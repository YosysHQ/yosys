log -header "Copy through sliced and concatenated port connections"
log -push
design -reset
read_verilog <<EOF
module m(input [3:0] i, output [1:0] y);
  assign y = {i[0] ^ i[3], i[1] & i[2]};
endmodule

module top(input [3:0] a, output [7:0] y);
  assign y[3:0] = a;
  assign y[7:6] = 2'b10;
  m u(.i({a[0], a[3], a[1], a[2]}), .y(y[5:4]));
endmodule
EOF
hierarchy -top top
