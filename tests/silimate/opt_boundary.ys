read_verilog -icells <<EOF
module m(input a, input b, output y);
  (* keep *) \$and #(
    .A_SIGNED(1'b0),
    .B_SIGNED(1'b0),
    .A_WIDTH(1),
    .B_WIDTH(1),
    .Y_WIDTH(1)
  ) kept_and (
    .A(a),
    .B(b),
    .Y(y)
  );
endmodule

module top(input a, input b, output y);
  m u(.a(a), .b(b), .y(y));
endmodule
EOF
