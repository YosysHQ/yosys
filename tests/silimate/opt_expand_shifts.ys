log -header "Negative case: fanout from intermediate wire prevents expansion"
log -push
design -reset
read_verilog <<EOF
module top (
  input wire [7:0] a,
  input wire [7:0] b,
  input wire [2:0] c,
  output wire [7:0] m,
  output wire [7:0] x
);
  assign m = a & b;
  assign x = m << c;
endmodule
EOF
check -assert
equiv_opt -assert opt_shift -expand
design -load postopt
select -assert-count 1 t:$and
select -assert-count 1 t:$shl
design -reset
log -pop



