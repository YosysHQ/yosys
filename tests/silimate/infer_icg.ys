log -header "Infer $icg from latch-based clock gate with scan enable"
log -push
design -reset
read_verilog -sv <<EOF
module top(input logic CK, EN, SE, output logic Q);
  logic en_ff;
  logic enable;

  assign enable = EN | SE;

  always_latch
    if (!CK)
      en_ff = enable;

  assign Q = CK & en_ff;
endmodule
EOF

