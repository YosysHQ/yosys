read_verilog <<EOT
module equiv_add3(
	input [3:0] a, b, c,
	output [3:0] y
);
	assign y = a + b + c;
endmodule
EOT
hierarchy -auto-top
proc
equiv_opt arith_tree
design -load postopt
select -assert-count 1 t:$fa
select -assert-count 1 t:$add
design -reset

