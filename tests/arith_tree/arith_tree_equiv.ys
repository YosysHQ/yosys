read_verilog <<EOT
module equiv_double_neg(
	input [3:0] a, b, c,
	output [3:0] y
);
	wire [3:0] ab = a - b;
	assign y = c - ab;
endmodule
EOT
hierarchy -auto-top
proc
equiv_opt arith_tree
design -load postopt
select -assert-count 2 t:$fa
select -assert-count 1 t:$add
design -reset
