read_verilog <<EOT
module four_op_42(
	input [3:0] a, b, c, d,
	output [3:0] y
);
	assign y = a + b + c + d;
endmodule
EOT
hierarchy -auto-top
proc
equiv_opt -assert arith_tree -strategy 42
design -load postopt
select -assert-count 2 t:$fa
select -assert-count 1 t:$add
select -assert-count 2 t:$fa c:*emit_compressor_42* %i
select -assert-count 0 t:$fa c:*emit_compressor_32* %i
design -reset

