read_verilog <<EOT
module signed_mac(
	input signed [3:0] a, b,
	input signed [7:0] c,
	output signed [7:0] y
);
	assign y = a * b + c;
endmodule
EOT
hierarchy -auto-top
proc
alumacc
opt
equiv_opt -assert arith_tree
design -load postopt
select -assert-count 0 t:$macc t:$macc_v2 %u
select -assert-count 0 t:$mul
select -assert-min 1 t:$fa
design -reset

read_verilog <<EOT
